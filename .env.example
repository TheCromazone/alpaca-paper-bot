ALPACA_API_KEY=your_key_here
ALPACA_API_SECRET=your_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# DRY_RUN=true skips order submission and only logs decisions.
DRY_RUN=true
DB_PATH=data/trading.db
LOG_LEVEL=INFO

# SEC EDGAR requires a descriptive user-agent (per their fair access policy).
SEC_USER_AGENT=your-app-name your-email@example.com

# Anthropic (Claude) — required once LLM_ROUTINES_ENABLED=true.
# Get a key at https://console.anthropic.com/settings/keys and paste it here.
# This file (.env.example) holds placeholders; real keys go in .env which is
# gitignored.
ANTHROPIC_API_KEY=sk-ant-your-key-here
LLM_MODEL=claude-opus-4-7
LLM_DAILY_USD_BUDGET=12.00
LLM_ROUTINES_ENABLED=true
