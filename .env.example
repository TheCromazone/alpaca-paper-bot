# --------------------------------------------------------------------------
# Alpaca (paper trading only — do not point this at a live account)
# --------------------------------------------------------------------------
ALPACA_API_KEY=your_alpaca_paper_key
ALPACA_API_SECRET=your_alpaca_paper_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# DRY_RUN=true short-circuits order submission — every place_buy/place_sell
# returns a fake order id and writes a "dry_run" Trade row. Use this for
# observation runs before flipping to false.
DRY_RUN=false
DB_PATH=data/trading.db
LOG_LEVEL=INFO

# SEC EDGAR requires a descriptive user-agent (per their fair-access policy).
SEC_USER_AGENT=your-app-name your-email@example.com

# --------------------------------------------------------------------------
# LLM provider — anthropic | codex_oauth
# --------------------------------------------------------------------------
# codex_oauth is the default: it uses the `codex-auth` PyPI shim to call
# OpenAI's Codex endpoint with your ChatGPT Plus/Pro OAuth token (cached at
# ~/.codex-auth/auth.json). Run `python scripts/_codex_oauth_bootstrap.py`
# once after install to do the browser sign-in. $0/call under the Plus
# subscription; ChatGPT-tier rate limits apply.
#
# anthropic is the fallback: per-token billing via the Anthropic Messages API.
# Set ANTHROPIC_API_KEY below and flip LLM_PROVIDER=anthropic if Codex breaks.
LLM_PROVIDER=codex_oauth
LLM_MODEL_CODEX=gpt-5.5
LLM_ROUTINES_ENABLED=true

# Anthropic fallback config — only needed when LLM_PROVIDER=anthropic.
# Get a key at https://console.anthropic.com/settings/keys. The real key
# lives in your .env (gitignored); this .env.example carries placeholders.
ANTHROPIC_API_KEY=sk-ant-your-key-here
LLM_MODEL=claude-opus-4-7
LLM_DAILY_USD_BUDGET=12.00
